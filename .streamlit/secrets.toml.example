# Streamlit Cloud secrets — copy contents into the Streamlit Cloud dashboard
# (App → Settings → Secrets) or into .streamlit/secrets.toml for local dev.
# Never commit .streamlit/secrets.toml — it's in .gitignore.

SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your-anon-key-here"
DEEPSEEK_API_KEY = "sk-..."

# Note: SUPABASE_SERVICE_KEY is only needed for ingest.py (local use).
# Do NOT add it to Streamlit Cloud secrets.
