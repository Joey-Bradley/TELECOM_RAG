# Copy this file to .env and fill in your values.
# Find these in Supabase → Project Settings → API

# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Anon/public key — used by the app (RLS enforced)
SUPABASE_KEY=your-anon-key-here

# Service role key — used only by ingest.py (bypasses RLS for writes)
# KEEP THIS SECRET — never expose it in the frontend
SUPABASE_SERVICE_KEY=your-service-role-key-here

# DeepSeek API key — optional; if set, users won't need to enter their own
# Get one at: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-...
